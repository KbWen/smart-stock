# Smart Stock Selector — Environment Variables
# Copy this file to .env and fill in values for your environment.
# .env is listed in .gitignore and must NEVER be committed.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Absolute path to the SQLite database file.
# Default: <repo-root>/storage.db
# DB_PATH=/absolute/path/to/storage.db

# SQLite busy-timeout in seconds.
# Default: 30.0
# DB_TIMEOUT=30.0

# ---------------------------------------------------------------------------
# AI Model
# ---------------------------------------------------------------------------
# Absolute path to the active model .pkl file.
# Default: <repo-root>/model_sniper.pkl
# MODEL_PATH=/absolute/path/to/model_sniper.pkl

# Look-ahead window for target labels (trading days, max 20).
# Default: 20
# PRED_DAYS=20

# Profit target threshold (fraction). e.g. 0.15 = +15%.
# Default: 0.15
# TARGET_GAIN=0.15

# Stop-loss threshold (fraction). e.g. 0.05 = -5%.
# Default: 0.05
# STOP_LOSS=0.05

# Buy-signal threshold (fraction). e.g. 0.10 = +10%.
# Default: 0.10
# BUY_TARGET=0.10

# ---------------------------------------------------------------------------
# Backtest / Strategy
# ---------------------------------------------------------------------------
# Minimum AI probability to count a signal as a buy in backtest.
# Default: 0.35
# BACKTEST_AI_THRESHOLD=0.35

# Minimum rows of OHLCV history required for training.
# Default: 260
# MIN_TRAIN_ROWS=260

# Minimum rows required for prediction (less strict than training).
# Default: 120
# MIN_PREDICT_ROWS=120

# ---------------------------------------------------------------------------
# Backend / System
# ---------------------------------------------------------------------------
# Number of concurrent workers for scoring pipeline.
# Default: 5
# CONCURRENCY_WORKERS=5

# Number of workers for model training.
# Default: max(2, CPU_COUNT - 1)
# TRAINING_WORKERS=4

# Allow GPU acceleration. Values: true | false | auto
# Default: auto (uses GPU if available)
# USE_GPU=auto

# API response cache duration in seconds.
# Default: 3600 (1 hour)
# CACHE_DURATION=3600

# Log verbosity. Values: DEBUG | INFO | WARNING | ERROR
# Default: INFO
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Model Integrity (optional HMAC signing)
# ---------------------------------------------------------------------------
# If set, trainer.py signs model files with HMAC-SHA256 on save, and
# predictor.py verifies the signature before loading. Leave unset for local dev.
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
# MODEL_SIGNING_KEY=your-secret-key-here

# ---------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins)
# If unset, defaults to localhost:5173 / 5174 / 3000 for local dev.
# In production, set this to your actual frontend domain(s).
# ---------------------------------------------------------------------------
# CORS_ORIGINS=https://your-frontend.example.com
